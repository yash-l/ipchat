# IPChat — production environment
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="replace-me"
JWT_SECRET="replace-with-openssl-rand-hex-32"
PHONE_HASH_SECRET="replace-with-a-different-openssl-rand-hex-32"
MESSAGE_ENCRYPTION_KEY="replace-with-openssl-rand-hex-32"
OWNER_PHONE_E164="+91XXXXXXXXXX"
OTP_DELIVERY_MODE="ADMIN_PORTAL"
SMS_PROVIDER_API_KEY=""

# Required for production passkeys. Do not rely only on forwarded headers.
PASSKEY_RP_ID="your-domain.example.com"
PASSKEY_ORIGIN="https://your-domain.example.com"
