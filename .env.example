# ---- Neon (Postgres, free tier) ----
# In the Neon dashboard, copy the "Pooled connection" string for DATABASE_URL
# and the "Direct connection" string for DIRECT_URL (used only by `prisma migrate`).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# ---- Upstash (Redis, free tier) ----
# From the Upstash console: Database -> REST API section.
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ---- Secrets (generate with: openssl rand -hex 32) ----
JWT_SECRET="replace-me"
PHONE_HASH_SECRET="replace-me-with-a-different-value"

# ---- SMS provider (optional in dev — codes are logged to the console instead) ----
SMS_PROVIDER_API_KEY=""
